[Default Applications]
# Solux OS — Aplicaciones por defecto para el uso diario
# Se instala en /etc/skel/.config/mimeapps.list

# Navegador web
x-scheme-handler/http=firefox-esr.desktop
x-scheme-handler/https=firefox-esr.desktop
x-scheme-handler/about=firefox-esr.desktop
x-scheme-handler/unknown=firefox-esr.desktop
text/html=firefox-esr.desktop

# Correo
x-scheme-handler/mailto=thunderbird.desktop

# Documentos
application/pdf=org.gnome.Evince.desktop
application/vnd.oasis.opendocument.text=libreoffice-writer.desktop
application/vnd.openxmlformats-officedocument.wordprocessingml.document=libreoffice-writer.desktop
application/msword=libreoffice-writer.desktop
application/vnd.ms-excel=libreoffice-calc.desktop
application/vnd.openxmlformats-officedocument.spreadsheetml.sheet=libreoffice-calc.desktop
application/vnd.ms-powerpoint=libreoffice-impress.desktop

# Texto plano
text/plain=org.xfce.mousepad.desktop

# Imágenes
image/jpeg=ristretto.desktop
image/png=ristretto.desktop
image/gif=ristretto.desktop
image/webp=ristretto.desktop
image/svg+xml=inkscape.desktop

# Audio y vídeo
audio/mpeg=vlc.desktop
audio/flac=vlc.desktop
video/mp4=vlc.desktop
video/x-matroska=vlc.desktop
video/webm=vlc.desktop

# Archivos comprimidos
application/zip=xarchiver.desktop
application/x-tar=xarchiver.desktop
application/x-7z-compressed=xarchiver.desktop
application/gzip=xarchiver.desktop

# Gestor de archivos
inode/directory=thunar.desktop
